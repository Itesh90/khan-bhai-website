# Database
DATABASE_URL="postgresql://user:password@localhost:5432/khan_bhai_db"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Razorpay Payment Gateway
# Test card: 4111 1111 1111 1111  ·  12/25  ·  CVV 123
# Test UPI:  success@razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxx"
# Required to verify Razorpay webhook signatures (Settings → Webhooks → Secret)
RAZORPAY_WEBHOOK_SECRET="xxxxxxxxxxxxxxxx"

# Email Configuration (Nodemailer)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-app-password"
EMAIL_FROM="noreply@khanbhaihotel.com"

# WhatsApp Integration (Optional)
WHATSAPP_BUSINESS_PHONE_NUMBER_ID="xxxxxxxxxxxxx"
WHATSAPP_BUSINESS_ACCOUNT_ACCESS_TOKEN="xxxxxxxxxxxxx"
# Used by emailService.sendOwnerWhatsAppNotice (optional)
OWNER_WHATSAPP_NUMBER="+919999999999"
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""

# Site Configuration
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Khan Bhai S."

# Admin Configuration
ADMIN_EMAIL="admin@khanbhaihotel.com"

# Feature Flags
NEXT_PUBLIC_ENABLE_BOOKINGS="true"
NEXT_PUBLIC_ENABLE_PAYMENTS="true"
NEXT_PUBLIC_ENABLE_CONTACT="true"
