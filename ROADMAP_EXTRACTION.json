  "section1_systemArchitecture": {
    "title": "System Architecture",
    "frontendLayer": {
      "framework": "Next.js 14 App Router",
      "components": [
        "React Server Components",
        "Tailwind CSS with custom gold tokens",
        "Framer Motion animations"
      ],
      "hosting": "Vercel (CDN edge)",
      "renderingModes": ["SSR", "ISR", "Edge"]
    },
    "backendLayer": {
      "framework": "Next.js API Routes (serverless)",
      "database": {
        "provider": "Prisma ORM",
        "database": "PostgreSQL via Supabase"
      },
      "authentication": "JWT-based auth (admin only)",
      "integrations": [
        "Razorpay webhook handler",
        "EmailJS + WhatsApp notifier"
      ],
      "architecture": ["REST", "Serverless", "Webhooks"]
    },
    "paymentSystem": {
      "provider": "Razorpay",
      "description": "Test mode → live. UPI, cards, netbanking. Webhook confirms payment server-side before booking is confirmed."
    },
    "notificationEngine": {
      "description": "On successful payment: EmailJS fires email to owner + auto-reply to customer. WhatsApp API sends booking summary."
    },
    "database": {
      "provider": "Supabase PostgreSQL (free tier)",
      "orm": "Prisma ORM",
      "features": ["Schema management", "Migrations", "Type-safe queries"]
    },
    "highLevelFlow": [
      "Visitor → Vercel CDN → Next.js Page",
      "→ Book Now → /checkout page",
      "→ Razorpay popup → Payment",
      "→ /api/payment/verify (server)",
      "→ Save booking to DB",
      "→ Email + WhatsApp owner",
      "→ /confirmation page"
    ]
  },

  "section2_techStack": {
    "title": "Full Tech Stack",
    "layers": [
      {
        "layer": "Framework",
        "technology": "Next.js 14 (App Router)",
        "why": "SEO, SSR, serverless API, Vercel-native, best for India"
      },
      {
        "layer": "Styling",
        "technology": "Tailwind CSS + custom tokens",
        "why": "Rapid black-gold design system, fully responsive"
      },
      {
        "layer": "Animation",
        "technology": "Framer Motion",
        "why": "Silky scroll animations, entrance effects, hover states"
      },
      {
        "layer": "Database",
        "technology": "PostgreSQL (Supabase)",
        "why": "Free tier, row-level security, real-time if needed"
      },
      {
        "layer": "ORM",
        "technology": "Prisma ORM",
        "why": "Type-safe DB queries, auto-migrations, great DX"
      },
      {
        "layer": "Auth",
        "technology": "NextAuth.js + JWT",
        "why": "Admin-only login, secure sessions, easy to set up"
      },
      {
        "layer": "Payments",
        "technology": "Razorpay SDK",
        "why": "India's #1, UPI + cards, test mode → live seamlessly"
      },
      {
        "layer": "Email",
        "technology": "Nodemailer + Gmail SMTP",
        "why": "Free, reliable, sends booking emails to owner"
      },
      {
        "layer": "WhatsApp",
        "technology": "WhatsApp Click-to-chat",
        "why": "Zero cost, instant, no API key needed for V1"
      },
      {
        "layer": "Hosting",
        "technology": "Vercel (free tier)",
        "why": "1-click deploy from Cursor, auto HTTPS, CDN globally"
      },
      {
        "layer": "Fonts",
        "technology": "Playfair Display + Poppins",
        "why": "Playfair = royal feel matching logo, Poppins = clean body"
      },
      {
        "layer": "Icons",
        "technology": "Lucide React",
        "why": "Consistent, clean, lightweight, tree-shakeable"
      },
      {
        "layer": "Images",
        "technology": "Next/Image + Unsplash",
        "why": "Auto-optimised, lazy-loaded, WebP conversion"
      },
      {
        "layer": "Forms",
        "technology": "React Hook Form + Zod",
