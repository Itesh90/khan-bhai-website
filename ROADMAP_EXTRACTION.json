    "title": "Authorization System",
    "userTypes": [
      {
        "type": "Visitors",
        "description": "Public, no login required"
      },
      {
        "type": "Admin",
        "description": "Owner/staff, protected dashboard"
      }
    ],
    "authFlow": [
      {
        "step": 1,
        "title": "Admin visits /admin/login",
        "description": "Email + password form"
      },
      {
        "step": 2,
        "title": "NextAuth verifies credentials",
        "description": "bcrypt compare + DB check"
      },
      {
        "step": 3,
        "title": "JWT session issued",
        "description": "HttpOnly cookie, 24hr expiry"
      },
      {
        "step": 4,
        "title": "Access granted",
        "description": "Redirect to /admin/dashboard"
      }
    ],
    "publicRoutes": [
      "/",
      "/restaurant",
      "/stay",
      "/travel",
      "/checkout",
      "/confirmation",
      "/contact",
      "/api/bookings (POST only)",
      "/api/payment/* (POST + webhook)"
    ],
    "protectedRoutes": [
      "/admin/login (Auth page)",
      "/admin/dashboard (Overview)",
      "/admin/bookings (All bookings)",
      "/admin/rooms (Manage rooms)",
      "/admin/tours (Manage tours)",
      "/admin/inquiries (Messages)",
      "/api/admin/* (All admin APIs)"
    ],
    "middlewareGuard": {
      "description": "next.config middleware.ts intercepts all /admin/* requests",
      "steps": [
        "Reads JWT from HttpOnly cookie",
        "Verifies signature with NEXTAUTH_SECRET",
        "If invalid/expired → redirect to /admin/login",
        "If valid → allow through to page"
      ]
    }
  },

  "section5_paymentAndSecurity": {
    "title": "Payment & Financial Security System",
    "razorpay": {
      "testMode": "V1 with test keys (rzp_test_xxxxxx)",
      "liveMode": "V2 after KYC (rzp_live_xxxxxx)",
      "methods": ["UPI", "credit/debit cards", "netbanking"],
      "currency": "INR",
      "cardDataHandling": "No card data ever touches your server"
    },
    "paymentFlow": [
      {
        "step": 1,
        "description": "Client clicks 'Pay Now'"
      },
      {
        "step": 2,
        "description": "/api/payment/create-order called"
      },
      {
        "step": 3,
        "description": "Razorpay returns order_id"
      },
      {
        "step": 4,
        "description": "Razorpay popup opens on client"
      },
      {
        "step": 5,
        "description": "Customer pays (UPI/card)"
      },
      {
        "step": 6,
        "description": "/api/payment/verify validates HMAC"
      },
      {
        "step": 7,
        "description": "Booking confirmed in DB"
      }
    ],
    "hmacVerification": {
      "title": "HMAC Signature Verification (Critical Security Step)",
      "process": [
        "Server receives: razorpay_order_id + razorpay_payment_id + razorpay_signature",
        "Server computes: HMAC-SHA256(order_id + '|' + payment_id, RAZORPAY_KEY_SECRET)",
        "Server compares: computed_hash === razorpay_signature",
        "If match → payment genuine → confirm booking",
        "If mismatch → reject → log fraud attempt → do NOT confirm"
      ]
    },
    "securityMeasures": [
      {
        "measure": "API Keys in .env only",
        "description": "RAZORPAY_KEY_ID and RAZORPAY_KEY_SECRET live only in server environment. Never exposed to client-side JS or committed to Git."
      },
      {
        "measure": "No card data stored",
        "description": "Razorpay handles all PCI DSS compliance. Your server never sees card numbers, CVV, or UPI PINs. Zero liability."
      },
      {
        "measure": "Webhook verification",
        "description": "Razorpay webhooks verified using X-Razorpay-Signature header + shared webhook secret. Prevents fake webhook triggers."
      },
      {
        "measure": "Rate limiting on payment API",
        "description": "Max 10 payment create-order requests per IP per hour. Prevents abuse and flooding using Vercel's edge middleware."
      },
      {
        "measure": "HTTPS enforced",
        "description": "Vercel automatically provisions SSL certificate. All traffic encrypted. HTTP redirects to HTTPS with HSTS headers."
      },
      {
        "measure": "Input sanitization",
        "description": "Zod schema validates all form inputs before any DB write. Prevents SQL injection (Prisma handles parameterized queries)."
      }
    ]
  },

