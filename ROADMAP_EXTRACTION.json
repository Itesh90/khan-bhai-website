  "section9_risksAndDecisions": {
    "title": "Risks & Decisions",
    "risks": [
      {
        "risk": "Razorpay KYC not complete for live mode",
        "likelihood": "High",
        "impact": "High",
        "mitigation": "Use test mode V1. Start KYC process immediately with client."
      },
      {
        "risk": "Real photos not ready for launch",
        "likelihood": "Medium",
        "impact": "Medium",
        "mitigation": "Launch with premium Unsplash stock photos, swap when client sends real ones."
      },
      {
        "risk": "Final room prices not confirmed",
        "likelihood": "Medium",
        "impact": "Low",
        "mitigation": "Use placeholder prices, add 'Contact for pricing' fallback CTA."
      },
      {
        "risk": "Owner WhatsApp number changes",
        "likelihood": "Low",
        "impact": "Medium",
        "mitigation": "Store number in .env variable — change in one place, updates everywhere."
      },
      {
        "risk": "Domain not purchased yet",
        "likelihood": "Medium",
        "impact": "Low",
        "mitigation": "Launch on khanbhais.vercel.app first, connect custom domain when ready."
      },
      {
        "risk": "No admin to manage bookings initially",
        "likelihood": "Medium",
        "impact": "Medium",
        "mitigation": "WhatsApp + email notifications are the primary system. Admin panel is a bonus."
      }
    ],
    "clientConfirmations": [
      "Final room prices",
      "Final tour prices",
      "Owner mobile for WhatsApp",
      "Owner email address",
      "Domain name preference",
      "Real restaurant photos (V2)",
      "Razorpay account creation"
    ]
  },

  "buildingSequenceAndDependencies": {
    "criticalPath": [
      {
        "phase": "Phase 0",
        "blocksAll": true,
        "reason": "Foundation must be complete before any development"
      },
      {
        "phase": "Phase 1",
        "dependsOn": ["Phase 0"],
        "reason": "Layout shell requires foundation setup"
      },
      {
        "phase": "Phase 2",
        "dependsOn": ["Phase 1"],
        "reason": "Service pages use navbar, footer, and routing from Phase 1"
      },
      {
        "phase": "Phase 3",
        "dependsOn": ["Phase 0", "Phase 2"],
        "reason": "Database design ready, API serves data from Phase 2 pages"
      },
      {
        "phase": "Phase 4",
        "dependsOn": ["Phase 3"],
        "reason": "Checkout needs working API routes and database"
      },
      {
        "phase": "Phase 5",
        "dependsOn": ["Phase 4"],
        "reason": "Notifications trigger after successful payment"
      },
      {
        "phase": "Phase 6",
        "dependsOn": ["Phase 3"],
        "reason": "Admin panel reads from bookings table"
      },
      {
        "phase": "Phase 7",
        "dependsOn": ["All previous phases"],
        "reason": "Polish and deploy only after all features are complete"
      }
    ],
    "parallelizableWork": [
      {
        "phase": "Phase 2",
        "tasks": "Restaurant, Rooms, and Tours pages can be built in parallel by different developers"
      },
      {
        "phase": "Phase 3 & 6",
        "tasks": "Database/API (Phase 3) and Admin Panel (Phase 6) can be worked on in parallel after Phase 0"
      }
    ]
  },

